# ─────────────────────────────────────────
# CheckAI Backend — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ─────────────────────────────────────────

PORT=3001
NODE_ENV=production
FRONTEND_URL=https://checkai.in

# ── HIVE AI (Image + Video detection) ────
# https://thehive.ai → Account → API Keys
HIVE_API_KEY=your_hive_api_key_here
HIVE_SECRET_KEY=your_hive_secret_key_here

# ── SAPLING AI (Text detection) ──────────
# https://sapling.ai → Dashboard → API Keys
SAPLING_API_KEY=your_sapling_api_key_here

# Google Fact Check Tools API (News verification)
# https://developers.google.com/fact-check/tools/api
GOOGLE_FACT_CHECK_API_KEY=AIzaSyCfYnc1TWO2_Ay8SmedhGnfBc4L57nkquk

# ── COPYLEAKS (Document detection) ───────
# https://copyleaks.com → Account → API Access
COPYLEAKS_EMAIL=your_copyleaks_email_here
COPYLEAKS_API_KEY=your_copyleaks_api_key_here

# ── FIREBASE ADMIN SDK ───────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── CASHFREE ─────────────────────────────
CASHFREE_APP_ID=your_cashfree_app_id_here
CASHFREE_SECRET_KEY=your_cashfree_secret_key_here
CASHFREE_ENV=PRODUCTION

# ── PLAN PRICING (in paise) ───────────────
PRO_PRICE_PAISE=49900
ENTERPRISE_PRICE_PAISE=299900

# ── RATE LIMITING ─────────────────────────
RATE_LIMIT_MAX=100
ANON_DAILY_LIMIT=5
FREE_MONTHLY_LIMIT=50
PRO_MONTHLY_LIMIT=5000
